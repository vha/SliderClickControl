{
  "$schema": "https://raw.githubusercontent.com/QuestPackageManager/QPM.Package/refs/heads/main/qpm.schema.json",
  "version": "0.1.0",
  "sharedDir": "shared",
  "dependenciesDir": "extern",
  "info": {
    "name": "Slider Click Control",
    "id": "sliderclickcontrol",
    "version": "1.0.0",
    "url": null,
    "additionalData": {
      "overrideSoName": "libsliderclickcontrol.so",
